{
  "version": "0.2.0",
  "configurations": [
    {
      "name": "调试 mugua-ai（Go / production）",
      "type": "go",
      "request": "launch",
      "mode": "auto",
      "program": "${workspaceFolder}",
      "cwd": "${workspaceFolder}",
      "buildFlags": "-tags=production",
      "env": {
        "CGO_ENABLED": "1",
        "CGO_LDFLAGS": "-framework UniformTypeIdentifiers -mmacosx-version-min=10.13"
      }
    }
  ]
}
